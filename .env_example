# =============================================================================
# Copie este arquivo para .env e preencha os valores antes de subir o ambiente.
#   cp .env_example .env
#
# NUNCA commite o arquivo .env — ele está no .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Projeto
# -----------------------------------------------------------------------------
PROJECT_NAME=ML-Engineering
PROJECT_VERSION=/v1

# -----------------------------------------------------------------------------
# Modo de operação
# -----------------------------------------------------------------------------
DEBUG=False

# -----------------------------------------------------------------------------
# Parâmetros de ML
# -----------------------------------------------------------------------------
TEST_SIZE=0.2
RANDOM_STATE=42

# Domínio ML quando o formulário não envia objective (rota POST .../train/baseline na API).
OBJECTIVE=churn

# Paralelismo joblib no pipeline FE (cross_val_score / tuning / permutation_importance):
#   auto (omissão) — threading dentro de tasks Airflow (variável AIRFLOW_CTX_DAG_ID presente),
#     para evitar Loky a recuar para n_jobs=1; fora do Airflow mantém o backend por omissão (loky).
#   threading | loky | multiprocessing — forçar backend explícito.
# Se a CPU “disparar” com threading+BLAS, experimente no container: OPENBLAS_NUM_THREADS=1
# Debug manual no VS Code (debugpy): n_jobs já fica em 1 e não se força parallel_backend.
# ML_PIPELINE_JOBLIB_BACKEND=auto

# Limiar P(classe positiva) para precision/recall/F1/accuracy nos relatórios (teste),
# quando ``predict_proba`` existe. CV/tuning continua com o limiar interno do sklearn.
# Airflow: override com ``decision_threshold`` no JSON da Variable / conf do trigger.
# CLASSIFICATION_DECISION_THRESHOLD=0.5

# Selector do backend de inferência:
#   true  → novos runs FE são gravados com inference_backend='mlp' e o promote vê só esses.
#           A predict carrega o bundle MLP (ckpt + preprocess + meta) do run promovido.
#   false → comportamento clássico (sklearn). O joblib promovido continua a servir.
# Notas:
#   - O switch só afecta novos treinos/promotes. O /predict segue o backend que ficou
#     gravado no run promovido — alterar a env não muda o que está em produção.
#   - Para activar o MLP em produção: colocar true → treinar FE → promover.
USE_MLP_FOR_PREDICTION=false

# -----------------------------------------------------------------------------
# Caminhos de artefatos (relativos ao CWD do processo = raiz do repo em dev / /var/www no Docker)
# Com Docker Compose actual, a API monta volumes em /var/www/src/{data,artifacts,graphs}
# e logs HTTP em /var/www/logs — ver docker-compose (serviço api_processing).
# -----------------------------------------------------------------------------
PATH_DATA=src/data/
PATH_DATA_PREPROCESSED=src/data/pre_processed/
PATH_MODEL=src/artifacts/models/
PATH_GRAPHS=src/graphs/
# Snapshot por corrida: PATH_DATA + PATH_LOGS + data/hora (input, graphs, logs de pipeline…). Para árvore tipo src/data/old/… use PATH_LOGS=old/
PATH_LOGS=logs/

# -----------------------------------------------------------------------------
# MLflow
# -----------------------------------------------------------------------------
# Desenvolvimento local (Python na raíz do repo, sem Docker):
MLFLOW_TRACKING_URI=sqlite:///src/artifacts/mlruns/mlflow.db
MLFLOW_ARTIFACT_ROOT=src/artifacts/mlruns
#
# Com docker compose, o serviço api_processing define em docker-compose.yaml:
#   MLFLOW_TRACKING_URI=sqlite:////var/www/ml_shared/mlflow.db
#   MLFLOW_ARTIFACT_ROOT=/var/www/ml_shared/mlruns
# Esses valores coincidem com o Airflow (mesmo volume ml_shared que /opt/airflow/ml_project).

# -----------------------------------------------------------------------------
# Relatórios de manutenção (drift, latência)
# -----------------------------------------------------------------------------
PATH_MAINTENANCE_REPORTS=src/artifacts/reports

# -----------------------------------------------------------------------------
# Logs de requisições HTTP
# -----------------------------------------------------------------------------
LOG_HTTP_REQUESTS=True
LOG_HTTP_REQUESTS_FILE=True
PATH_API_REQUEST_LOGS=logs/api_requests
LOG_HTTP_REQUESTS_MAX_BYTES=5242880
LOG_HTTP_REQUESTS_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Banco de dados PostgreSQL
# DATABASE_SERVER deve ser "db_processing" quando rodando via docker compose,
# ou "localhost" para desenvolvimento local sem container.
# -----------------------------------------------------------------------------
DATABASE_USER=seu_usuario
DATABASE_PASS=sua_senha_segura
DATABASE_SERVER=db_processing
DATABASE_PORT=5432
DATABASE_NAME=processing

# -----------------------------------------------------------------------------
# Autenticação JWT
# SECRET: gere com  python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET=troque_por_um_valor_gerado_aleatorio
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# pgAdmin (interface web do banco — só usado no docker compose)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@exemplo.com
PGADMIN_PASSWORD=sua_senha_pgadmin

# -----------------------------------------------------------------------------
# Airflow (gerado automaticamente no primeiro `docker compose up`)
# AIRFLOW_UID: rodar `echo "AIRFLOW_UID=$(id -u)" >> .env` antes de subir
# Cada variável em uma linha (evite colar duas chaves na mesma linha, ex.: ...=2AIRFLOW_UID=...)
# -----------------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW_BASE_URL=http://airflow-webserver:8080
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow

# Chave partilhada webserver + scheduler (logs de tasks na UI; JWT na porta 8793).
# Recomendado: openssl rand -hex 32 — descomenta na tua cópia ``.env`` se quiseres chave própria:
# AIRFLOW_WEBSERVER_SECRET_KEY=coloque_aqui_hex_64_chars
# -----------------------------------------------------------------------------
# Volume compartilhado API <-> Airflow (caminho dentro do container da API)
# docker-compose: ml_shared em /var/www/ml_shared + bind ./ml_data/uploads -> .../uploads
# No host: colocar CSVs em ml_data/uploads/ (glob *.csv ignorado no git)
# -----------------------------------------------------------------------------
ML_SHARED_PATH=/var/www/ml_shared/uploads
